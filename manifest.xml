<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xsi:type="MailApp">

  <!-- ═══════════════════════════════════════════════
       IDENTITY
       ═══════════════════════════════════════════════ -->
  <Id>a1b2c3d4-e5f6-7890-abcd-ef1234567890</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>Naqeeb Ch</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="Email to PDF"/>
  <Description DefaultValue="Convert any open email to a PDF — 100% private, processed on your device."/>

  <!-- ═══════════════════════════════════════════════
       ICONS
       ═══════════════════════════════════════════════ -->
  <IconUrl DefaultValue="https://naqeebch.github.io/email_to_pdf_outlook_addin/assets/icon-80.png"/>
  <HighResolutionIconUrl DefaultValue="https://naqeebch.github.io/email_to_pdf_outlook_addin/assets/icon-80.png"/>
  <SupportUrl DefaultValue="https://naqeebch.github.io/email_to_pdf_outlook_addin"/>

  <!-- ═══════════════════════════════════════════════
       REQUIREMENTS
       ═══════════════════════════════════════════════ -->
  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.3"/>
    </Sets>
  </Requirements>

  <!-- ═══════════════════════════════════════════════
       FORM SETTINGS  (base manifest — read mode)
       ═══════════════════════════════════════════════ -->
  <FormSettings>
    <Form xsi:type="ItemRead">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://naqeebch.github.io/email_to_pdf_outlook_addin/taskpane/taskpane.html"/>
        <RequestedHeight>250</RequestedHeight>
      </DesktopSettings>
    </Form>
  </FormSettings>

  <!-- ═══════════════════════════════════════════════
       PERMISSIONS
       ═══════════════════════════════════════════════ -->
  <Permissions>ReadItem</Permissions>

  <!-- ═══════════════════════════════════════════════
       ACTIVATION RULES
       ═══════════════════════════════════════════════ -->
  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Read"/>
  </Rule>

  <DisableEntityHighlighting>false</DisableEntityHighlighting>

  <!-- ═══════════════════════════════════════════════
       VERSION OVERRIDES v1.0
       Adds the ribbon button in Outlook Desktop
       ═══════════════════════════════════════════════ -->
  <VersionOverrides
    xmlns="http://schemas.microsoft.com/office/mailappversionoverrides"
    xsi:type="VersionOverridesV1_0">

    <Requirements>
      <bt:Sets DefaultMinVersion="1.3">
        <bt:Set Name="Mailbox" MinVersion="1.3"/>
      </bt:Sets>
    </Requirements>

    <Hosts>
      <Host xsi:type="MailHost">
        <DesktopFormFactor>

          <!-- Required placeholder for function-based commands -->
          <FunctionFile resid="Commands.Url"/>

          <!-- Ribbon button when reading a message -->
          <ExtensionPoint xsi:type="MessageReadCommandSurface">
            <OfficeTab id="TabDefault">
              <Group id="EmailToPDF.Group">
                <Label resid="GroupLabel"/>

                <Control xsi:type="Button" id="EmailToPDF.Button">
                  <Label resid="ButtonLabel"/>
                  <Supertip>
                    <Title resid="ButtonLabel"/>
                    <Description resid="ButtonTooltip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon16"/>
                    <bt:Image size="32" resid="Icon32"/>
                    <bt:Image size="80" resid="Icon80"/>
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <SourceLocation resid="TaskpaneUrl"/>
                  </Action>
                </Control>

              </Group>
            </OfficeTab>
          </ExtensionPoint>

        </DesktopFormFactor>
      </Host>
    </Hosts>

    <Resources>
      <bt:Images>
        <bt:Image id="Icon16" DefaultValue="https://naqeebch.github.io/email_to_pdf_outlook_addin/assets/icon-16.png"/>
        <bt:Image id="Icon32" DefaultValue="https://naqeebch.github.io/email_to_pdf_outlook_addin/assets/icon-32.png"/>
        <bt:Image id="Icon80" DefaultValue="https://naqeebch.github.io/email_to_pdf_outlook_addin/assets/icon-80.png"/>
      </bt:Images>
      <bt:Urls>
        <bt:Url id="Commands.Url"  DefaultValue="https://naqeebch.github.io/email_to_pdf_outlook_addin/taskpane/commands.html"/>
        <bt:Url id="TaskpaneUrl"   DefaultValue="https://naqeebch.github.io/email_to_pdf_outlook_addin/taskpane/taskpane.html"/>
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="GroupLabel"    DefaultValue="Email Tools"/>
        <bt:String id="ButtonLabel"   DefaultValue="Save as PDF"/>
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="ButtonTooltip" DefaultValue="Convert this email to a PDF file. Fully private — processed on your device only."/>
      </bt:LongStrings>
    </Resources>

    <!-- ═══════════════════════════════════════════════
         VERSION OVERRIDES v1.1 (nested inside v1.0)
         Adds Outlook Web App support
         ═══════════════════════════════════════════════ -->
    <VersionOverrides
      xmlns="http://schemas.microsoft.com/office/mailappversionoverrides/1.1"
      xsi:type="VersionOverridesV1_1">

      <Requirements>
        <bt:Sets DefaultMinVersion="1.3">
          <bt:Set Name="Mailbox" MinVersion="1.3"/>
        </bt:Sets>
      </Requirements>

      <Hosts>
        <Host xsi:type="MailHost">
          <DesktopFormFactor>

            <FunctionFile resid="Commands.Url"/>

            <ExtensionPoint xsi:type="MessageReadCommandSurface">
              <OfficeTab id="TabDefault">
                <Group id="EmailToPDF.Group.v11">
                  <Label resid="GroupLabel"/>

                  <Control xsi:type="Button" id="EmailToPDF.Button.v11">
                    <Label resid="ButtonLabel"/>
                    <Supertip>
                      <Title resid="ButtonLabel"/>
                      <Description resid="ButtonTooltip"/>
                    </Supertip>
                    <Icon>
                      <bt:Image size="16" resid="Icon16"/>
                      <bt:Image size="32" resid="Icon32"/>
                      <bt:Image size="80" resid="Icon80"/>
                    </Icon>
                    <Action xsi:type="ShowTaskpane">
                      <SourceLocation resid="TaskpaneUrl"/>
                    </Action>
                  </Control>

                </Group>
              </OfficeTab>
            </ExtensionPoint>

          </DesktopFormFactor>
        </Host>
      </Hosts>

      <Resources>
        <bt:Images>
          <bt:Image id="Icon16" DefaultValue="https://naqeebch.github.io/email_to_pdf_outlook_addin/assets/icon-16.png"/>
          <bt:Image id="Icon32" DefaultValue="https://naqeebch.github.io/email_to_pdf_outlook_addin/assets/icon-32.png"/>
          <bt:Image id="Icon80" DefaultValue="https://naqeebch.github.io/email_to_pdf_outlook_addin/assets/icon-80.png"/>
        </bt:Images>
        <bt:Urls>
          <bt:Url id="Commands.Url"  DefaultValue="https://naqeebch.github.io/email_to_pdf_outlook_addin/taskpane/commands.html"/>
          <bt:Url id="TaskpaneUrl"   DefaultValue="https://naqeebch.github.io/email_to_pdf_outlook_addin/taskpane/taskpane.html"/>
        </bt:Urls>
        <bt:ShortStrings>
          <bt:String id="GroupLabel"    DefaultValue="Email Tools"/>
          <bt:String id="ButtonLabel"   DefaultValue="Save as PDF"/>
        </bt:ShortStrings>
        <bt:LongStrings>
          <bt:String id="ButtonTooltip" DefaultValue="Convert this email to a PDF file. Fully private — processed on your device only."/>
        </bt:LongStrings>
      </Resources>

    </VersionOverrides>
    <!-- end v1.1 -->

  </VersionOverrides>
  <!-- end v1.0 -->

</OfficeApp>
